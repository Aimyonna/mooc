# ============================================================
# MOOC 爬虫 — 环境变量模板
# 使用方式：复制为 .env 并填入真实值
#           cp .env.example .env
# ============================================================

# --- 数据库 ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=mooc
DB_CHARSET=utf8mb4

# --- 文件路径（相对于项目根目录） ---
COOKIE_FILE=cookies.json
COURSES_FILE=courses.txt

# --- 浏览器 ---
HEADLESS=false

# --- 日志 ---
LOG_LEVEL=INFO
LOG_DIR=logs
